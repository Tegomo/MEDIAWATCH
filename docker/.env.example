# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_PASSWORD=mediawatch_secret

# ─── JWT Secret (min 32 chars) ────────────────────────────
# Utilisé par GoTrue, PostgREST, et Kong
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ─── Supabase Keys ────────────────────────────────────────
# Générés avec le JWT_SECRET ci-dessus.
# Pour regénérer : https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Payload anon : {"role":"anon","iss":"supabase","iat":1735689600,"exp":1893456000}
# Payload service_role : {"role":"service_role","iss":"supabase","iat":1735689600,"exp":1893456000}

