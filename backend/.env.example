# Application
APP_NAME=MediaWatch CI
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Supabase (Base de données + Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Database - Utiliser la connection string Supabase
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@db.xxxxx.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@mediawatch.ci
SENDGRID_FROM_NAME=MediaWatch CI

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Orange Money (Paiements CI)
ORANGE_MONEY_API_KEY=your_orange_money_api_key
ORANGE_MONEY_MERCHANT_KEY=your_merchant_key
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/ci/v1

# Storage (S3-compatible / Supabase Storage)
STORAGE_BUCKET=mediawatch-exports
STORAGE_URL=https://your-project.supabase.co/storage/v1

# NLP Models
SPACY_MODEL=fr_core_news_lg
CAMEMBERT_MODEL=camembert-base

# Scraping
SCRAPING_USER_AGENT=MediaWatch CI Bot/1.0
SCRAPING_RATE_LIMIT=30
PLAYWRIGHT_HEADLESS=True

# Jina AI Reader (Scraping intelligent)
JINA_API_KEY=your_jina_api_key_here

# Monitoring
SENTRY_DSN=your_sentry_dsn_here

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API
API_V1_PREFIX=/v1
